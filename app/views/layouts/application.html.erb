<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Personal Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Personal Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Meta tags %>
    <% meta_title = content_for?(:og_title) ? yield(:og_title) : 'Esteban Soto' %>
    <% meta_description = content_for?(:og_description) ? yield(:og_description) : 'Full-stack developer writing about Ruby, JavaScript, and software engineering.' %>
    <% canonical_url = request.base_url + request.path %>
    <meta name="description" content="<%= meta_description %>">
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:type" content="<%= content_for?(:og_type) ? yield(:og_type) : 'website' %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:site_name" content="Esteban Soto">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <link rel="canonical" href="<%= canonical_url %>">

    <%= yield :head %>

    <%# RSS Feed auto-discovery %>
    <%= auto_discovery_link_tag :rss, feed_url(format: :rss), title: "Esteban Soto RSS Feed" %>

    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%# Highlight.js for syntax highlighting %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.11.1/styles/github-dark.min.css"
          integrity="sha384-wH75j6z1lH97ZOpMOInqhgKzFkAInZPPSPlZpYKYTOqsaizPvhQZmAtLcPKXpLyH"
          crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.11.1/highlight.min.js"
            integrity="sha384-RH2xi4eIQ/gjtbs9fUXM68sLSi99C7ZWBRX1vDrVv6GQXRibxXLbwO2NGZB74MbU"
            crossorigin="anonymous"></script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg-primary text-text-primary min-h-screen flex flex-col">
    <!-- Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-bg-surface border-b border-border">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Site Logo/Name -->
          <div class="flex items-center">
            <%= link_to "Esteban Soto", root_path, class: "text-xl font-bold text-accent-blue hover:text-accent-green transition-fast" %>
          </div>

          <!-- Navigation Links -->
          <div class="flex items-center gap-6">
            <%= link_to "Posts", posts_path, class: nav_link_class("/posts", prefix_match: true) %>
            <%= link_to "Tags", tags_path, class: nav_link_class("/tags", prefix_match: true) %>
            <% if logged_in? %>
              <%= link_to "Admin", admin_root_path, class: "px-4 py-2 bg-bg-surface-hover border border-border hover:border-accent-blue text-text-primary rounded transition-fast" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice.present? %>
      <div class="mx-auto max-w-5xl w-full px-4 sm:px-6 lg:px-8 mt-4" data-controller="toast">
        <div class="bg-bg-surface border border-accent-green rounded-lg px-4 py-3 text-accent-green flex items-center justify-between gap-4 animate-in fade-in slide-in-from-top duration-300">
          <span><%= notice %></span>
          <button type="button" data-action="click->toast#dismiss" class="text-accent-green hover:text-accent-green/80 transition-fast">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </button>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mx-auto max-w-5xl w-full px-4 sm:px-6 lg:px-8 mt-4" data-controller="toast">
        <div class="bg-bg-surface border border-accent-orange rounded-lg px-4 py-3 text-accent-orange flex items-center justify-between gap-4 animate-in fade-in slide-in-from-top duration-300">
          <span><%= alert %></span>
          <button type="button" data-action="click->toast#dismiss" class="text-accent-orange hover:text-accent-orange/80 transition-fast">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </button>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="flex-1 max-w-5xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-bg-surface border-t border-border mt-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-8">
          <div class="text-text-secondary text-sm">
            <p>&copy; <%= Time.current.year %> Esteban Soto. All rights reserved.</p>
          </div>
          <div class="flex gap-6 text-text-secondary">
            <a href="https://github.com/esoto" target="_blank" rel="noopener noreferrer" class="hover:text-accent-blue transition-fast">GitHub</a>
            <a href="https://www.linkedin.com/in/soto-esteban/" target="_blank" rel="noopener noreferrer" class="hover:text-accent-blue transition-fast">LinkedIn</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
