<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - Personal Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Personal Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Google Fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg-primary text-text-primary min-h-screen flex flex-col">
    <!-- Admin Navigation Bar -->
    <nav class="sticky top-0 z-50 bg-bg-surface border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <!-- Admin Logo -->
          <div class="flex items-center gap-4">
            <%= link_to "Admin Dashboard", admin_root_path, class: "text-xl font-bold text-accent-blue hover:text-accent-green transition-fast" %>
          </div>

          <!-- Admin Navigation Links -->
          <div class="flex items-center gap-6">
            <%= link_to "Dashboard", admin_root_path, class: "text-text-primary hover:text-accent-blue transition-fast" %>
            <%= link_to "Posts", admin_posts_path, class: "text-text-primary hover:text-accent-blue transition-fast" %>
            <%= link_to "Tags", admin_tags_path, class: "text-text-primary hover:text-accent-blue transition-fast" %>
            <%= link_to "Comments", admin_comments_path, class: "text-text-primary hover:text-accent-blue transition-fast" %>
            <%= button_to "Logout", logout_path, method: :delete, form: { class: "inline" }, class: "px-4 py-2 bg-bg-surface-hover border border-border hover:border-accent-orange text-text-primary rounded transition-fast" %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <% if notice.present? %>
      <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-bg-surface border border-accent-green rounded-lg px-4 py-3 text-accent-green flex items-center justify-between gap-4 animate-in fade-in slide-in-from-top duration-300">
          <span><%= notice %></span>
          <button type="button" data-dismiss-toast class="text-accent-green hover:text-accent-green/80 transition-fast">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </button>
        </div>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8 mt-4">
        <div class="bg-bg-surface border border-accent-orange rounded-lg px-4 py-3 text-accent-orange flex items-center justify-between gap-4 animate-in fade-in slide-in-from-top duration-300">
          <span><%= alert %></span>
          <button type="button" data-dismiss-toast class="text-accent-orange hover:text-accent-orange/80 transition-fast">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </button>
        </div>
      </div>
    <% end %>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-bg-surface border-t border-border mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="text-text-secondary text-sm text-center">
          <p>&copy; <%= Time.current.year %> Personal Blog Admin. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      document.querySelectorAll('[data-dismiss-toast]').forEach(btn => {
        btn.addEventListener('click', () => btn.closest('[class*="bg-bg-surface"]').remove());
      });
    </script>
  </body>
</html>
