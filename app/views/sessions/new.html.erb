<div class="min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <!-- Card -->
    <div class="bg-bg-surface border border-border rounded-lg p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-text-primary mb-2">Sign In</h1>
        <p class="text-text-secondary">Access your admin dashboard</p>
      </div>

      <!-- Alert -->
      <% if flash[:alert] %>
        <div class="mb-6 bg-bg-primary border border-accent-orange rounded-lg px-4 py-3 text-accent-orange flex items-start gap-3">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>

      <!-- Form -->
      <%= form_with url: login_path, method: :post, local: true do |f| %>
        <!-- Email Field -->
        <div class="mb-5">
          <%= f.label :email, "Email Address", class: "block text-text-primary font-medium mb-2" %>
          <%= f.email_field :email, autofocus: true, required: true, placeholder: "your@email.com", class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast" %>
        </div>

        <!-- Password Field -->
        <div class="mb-6">
          <%= f.label :password, "Password", class: "block text-text-primary font-medium mb-2" %>
          <%= f.password_field :password, required: true, placeholder: "••••••••", class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast" %>
        </div>

        <!-- Submit Button -->
        <div class="mb-6">
          <%= f.submit "Sign In", class: "w-full px-4 py-2 bg-accent-blue hover:bg-accent-blue/90 text-bg-primary font-semibold rounded-lg transition-fast cursor-pointer" %>
        </div>
      <% end %>

      <!-- Footer Info -->
      <div class="pt-6 border-t border-border text-center text-text-secondary text-sm">
        <p>Contact an administrator if you need access</p>
      </div>
    </div>
  </div>
</div>
