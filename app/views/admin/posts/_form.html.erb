<%= form_with(model: [:admin, post], local: true) do |f| %>
  <!-- Error Messages -->
  <% if post.errors.any? %>
    <div class="mb-6 bg-bg-primary border border-accent-orange rounded-lg px-4 py-4">
      <h2 class="text-accent-orange font-semibold mb-3">
        <%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:
      </h2>
      <ul class="space-y-1 text-accent-orange text-sm">
        <% post.errors.full_messages.each do |message| %>
          <li>• <%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title Field -->
  <div class="mb-6">
    <%= f.label :title, "Post Title", class: "block text-text-primary font-semibold mb-2" %>
    <%= f.text_field :title, placeholder: "Enter post title", class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast" %>
  </div>

  <!-- Excerpt Field -->
  <div class="mb-6">
    <%= f.label :excerpt, "Excerpt", class: "block text-text-primary font-semibold mb-2" %>
    <%= f.text_area :excerpt, rows: 3, placeholder: "Brief summary of your post", class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast resize-none" %>
  </div>

  <!-- Content Field - Markdown Editor -->
  <div class="mb-6" data-controller="markdown-editor" data-markdown-editor-preview-url-value="<%= admin_posts_preview_path %>">
    <%= f.label :body_markdown, "Content", class: "block text-text-primary font-semibold mb-2" %>

    <!-- Toolbar -->
    <div class="flex flex-wrap gap-1 mb-2 p-2 bg-bg-primary border border-border rounded-t-lg">
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#bold" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm font-bold" title="Bold">B</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#italic" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm italic" title="Italic">I</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#strikethrough" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm line-through" title="Strikethrough">S</button>
      <span class="border-l border-border mx-1"></span>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#heading" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm font-bold" title="Heading">H</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#quote" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm" title="Quote">&ldquo;</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#code" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm font-mono" title="Inline Code">&lt;/&gt;</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#codeBlock" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm font-mono" title="Code Block">{}</button>
      <span class="border-l border-border mx-1"></span>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#bulletList" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm" title="Bullet List">&#8226;</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#numberList" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm" title="Numbered List">1.</button>
      <span class="border-l border-border mx-1"></span>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#link" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm" title="Link">Link</button>
      <button type="button" data-action="mousedown->markdown-editor#saveSelection markdown-editor#image" class="px-2 py-1 text-text-secondary hover:text-text-primary hover:bg-bg-card rounded text-sm" title="Image">Img</button>
    </div>

    <!-- Split Pane -->
    <div class="grid grid-cols-2 gap-4">
      <!-- Editor -->
      <div>
        <div class="text-xs text-text-muted mb-1 uppercase tracking-wider">Markdown</div>
        <%= f.text_area :body_markdown,
          rows: 20,
          placeholder: "Write your post in Markdown...",
          class: "w-full px-4 py-3 bg-bg-primary border border-border rounded-lg text-text-primary placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast font-mono text-sm leading-relaxed resize-y",
          data: { markdown_editor_target: "input", action: "input->markdown-editor#onInput" } %>
      </div>

      <!-- Preview -->
      <div>
        <div class="text-xs text-text-muted mb-1 uppercase tracking-wider">Preview</div>
        <div data-markdown-editor-target="preview"
             class="w-full px-4 py-3 bg-bg-primary border border-border rounded-lg text-text-primary overflow-y-auto prose-dark"
             style="min-height: 30em;">
          <p class="text-text-muted italic">Preview will appear here...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Field -->
  <div class="mb-6">
    <%= f.label :status, "Status", class: "block text-text-primary font-semibold mb-2" %>
    <%= f.select :status, Post.statuses.keys.map { |s| [s.capitalize, s] }, {}, class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast" %>
  </div>

  <!-- Published At Field -->
  <div class="mb-6">
    <%= f.label :published_at, "Published At", class: "block text-text-primary font-semibold mb-2" %>
    <%= f.datetime_field :published_at, class: "w-full px-4 py-2 bg-bg-primary border border-border rounded-lg text-text-primary focus:outline-none focus:ring-2 focus:ring-accent-blue focus:border-transparent transition-fast" %>
  </div>

  <!-- Tags Field -->
  <div class="mb-8">
    <%= f.label :tag_ids, "Tags", class: "block text-text-primary font-semibold mb-4" %>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <%= f.collection_check_boxes :tag_ids, Tag.all, :id, :name do |b| %>
        <label class="flex items-center gap-3 px-4 py-3 bg-bg-primary border border-border rounded-lg cursor-pointer hover:border-accent-blue transition-fast">
          <%= b.check_box class: "w-4 h-4 accent-accent-blue" %>
          <span class="text-text-primary font-medium"><%= b.object.name %></span>
        </label>
      <% end %>
    </div>
    <% if Tag.none? %>
      <p class="text-text-secondary text-sm mt-3">No tags available. <%= link_to "Create a tag", new_admin_tag_path, class: "text-accent-blue hover:text-accent-blue/80" %></p>
    <% end %>
  </div>

  <!-- Submit Buttons -->
  <div class="flex gap-4">
    <%= f.submit "Save Post", class: "px-6 py-3 bg-accent-green hover:bg-accent-green/90 text-bg-primary font-semibold rounded-lg transition-fast cursor-pointer" %>
    <%= link_to "Cancel", admin_posts_path, class: "px-6 py-3 border border-border hover:border-accent-blue text-text-primary font-semibold rounded-lg transition-fast" %>
  </div>
<% end %>
