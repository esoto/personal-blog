<h1>Posts</h1>

<p><%= link_to "New Post", new_admin_post_path %></p>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Status</th>
      <th>Published At</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= link_to post.title, admin_post_path(post) %></td>
        <td><%= post.status.capitalize %></td>
        <td><%= post.published_at&.strftime("%Y-%m-%d %H:%M") %></td>
        <td>
          <%= link_to "Edit", edit_admin_post_path(post) %>
          <%= button_to "Delete", admin_post_path(post), method: :delete, data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
