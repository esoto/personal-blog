<h1><%= @post.title %></h1>

<p><strong>Status:</strong> <%= @post.status.capitalize %></p>
<p><strong>Published At:</strong> <%= @post.published_at&.strftime("%Y-%m-%d %H:%M") || "Not published" %></p>
<p><strong>Excerpt:</strong> <%= @post.excerpt %></p>

<div>
  <%= @post.body %>
</div>

<p>
  <%= link_to "Edit", edit_admin_post_path(@post) %>
  <%= link_to "Back to Posts", admin_posts_path %>
</p>
