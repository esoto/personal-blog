<% content_for(:title) { "Tags" } %>

<div class="mb-8 flex justify-between items-center">
  <div>
    <h1 class="text-4xl font-bold text-text-primary mb-2">Tags</h1>
    <p class="text-text-secondary">Manage all your post tags</p>
  </div>
  <%= link_to "New Tag", new_admin_tag_path, class: "px-6 py-3 bg-accent-blue hover:bg-accent-blue/90 text-bg-primary font-semibold rounded-lg transition-fast" %>
</div>

<div class="bg-bg-surface border border-border rounded-lg overflow-hidden">
  <% if @tags.any? %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border">
            <th class="px-6 py-4 text-left text-sm font-semibold text-text-secondary">Name</th>
            <th class="px-6 py-4 text-left text-sm font-semibold text-text-secondary">Slug</th>
            <th class="px-6 py-4 text-left text-sm font-semibold text-text-secondary">Posts</th>
            <th class="px-6 py-4 text-left text-sm font-semibold text-text-secondary">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @tags.each do |tag| %>
            <tr class="border-b border-border hover:bg-bg-surface-hover transition-fast">
              <td class="px-6 py-4 text-text-primary font-medium"><%= tag.name %></td>
              <td class="px-6 py-4 text-text-secondary font-mono text-sm"><%= tag.slug %></td>
              <td class="px-6 py-4 text-text-primary">
                <span class="inline-block px-3 py-1 bg-bg-primary border border-border text-text-primary text-sm font-medium rounded-full"><%= tag.posts_count %></span>
              </td>
              <td class="px-6 py-4">
                <div class="flex gap-3">
                  <%= link_to "Edit", edit_admin_tag_path(tag), class: "text-accent-blue hover:text-accent-blue/80 transition-fast" %>
                  <%= button_to "Delete", admin_tag_path(tag), method: :delete, data: { turbo_confirm: "Are you sure?" }, form: { class: "inline" }, class: "text-accent-orange hover:text-accent-orange/80 transition-fast bg-none border-none p-0 cursor-pointer" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-text-secondary mb-6">No tags yet. Create your first tag to organize your posts!</p>
      <%= link_to "Create Tag", new_admin_tag_path, class: "inline-block px-6 py-3 bg-accent-blue hover:bg-accent-blue/90 text-bg-primary font-semibold rounded-lg transition-fast" %>
    </div>
  <% end %>
</div>
