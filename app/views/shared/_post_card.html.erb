<div class="group bg-bg-surface rounded-lg p-6 border border-border hover:border-accent-green transition-fast cursor-pointer overflow-hidden relative">
  <!-- Glow effect on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-br from-accent-green/5 to-accent-green/5 pointer-events-none"></div>

  <div class="relative z-10">
    <!-- Title -->
    <h3 class="text-xl font-bold text-accent-green mb-3 group-hover:text-accent-green transition-fast">
      <%= link_to post.title, post_show_path(slug: post.slug) %>
    </h3>

    <!-- Excerpt -->
    <p class="text-text-secondary mb-4 line-clamp-2 text-sm leading-relaxed">
      <%= post.excerpt %>
    </p>

    <!-- Meta -->
    <div class="flex items-center justify-between mb-4">
      <%= render "shared/post_meta", post: post %>
    </div>

    <!-- Tags -->
    <%= render "shared/post_tag_list", post: post, wrapper_class: "pt-4 border-t border-border" %>
  </div>
</div>
