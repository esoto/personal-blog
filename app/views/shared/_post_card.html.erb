<div class="bg-gray-800 rounded-lg p-6 border border-gray-700 hover:border-blue-400 transition-colors">
  <h3 class="text-xl font-bold text-blue-400 mb-3 hover:text-blue-300 transition-colors">
    <%= link_to post.title, "/posts/#{post.slug}" %>
  </h3>

  <p class="text-gray-300 mb-4 line-clamp-2">
    <%= post.excerpt %>
  </p>

  <div class="flex items-center justify-between mb-4">
    <span class="text-sm text-gray-400">
      <%= post.published_at.strftime("%b %d, %Y") %>
    </span>
  </div>

  <% if post.tags.any? %>
    <div class="flex flex-wrap gap-2">
      <% post.tags.each do |tag| %>
        <span class="inline-block bg-gray-700 text-gray-200 text-xs font-semibold px-3 py-1 rounded-full">
          <%= tag.name %>
        </span>
      <% end %>
    </div>
  <% end %>
</div>
