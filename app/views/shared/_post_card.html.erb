<div class="group bg-bg-surface rounded-lg p-6 border border-border hover:border-accent-blue transition-fast cursor-pointer overflow-hidden relative">
  <!-- Glow effect on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-br from-accent-blue/5 to-accent-green/5 pointer-events-none"></div>

  <div class="relative z-10">
    <!-- Title -->
    <h3 class="text-xl font-bold text-accent-blue mb-3 group-hover:text-accent-green transition-fast">
      <%= link_to post.title, post_show_path(slug: post.slug) %>
    </h3>

    <!-- Excerpt -->
    <p class="text-text-secondary mb-4 line-clamp-2 text-sm leading-relaxed">
      <%= post.excerpt %>
    </p>

    <!-- Meta Information -->
    <div class="flex items-center justify-between mb-4">
      <span class="text-text-muted text-xs font-medium">
        <%= post.published_at.strftime("%b %d, %Y") %>
      </span>
    </div>

    <!-- Tags -->
    <% if post.tags.any? %>
      <div class="flex flex-wrap gap-2 pt-4 border-t border-border">
        <% post.tags.each do |tag| %>
          <%= link_to tag.name, tag_path(slug: tag.slug), class: "inline-block bg-bg-primary border border-border/50 text-text-secondary text-xs font-medium px-3 py-1 rounded-full hover:border-accent-blue hover:text-accent-blue transition-fast" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>