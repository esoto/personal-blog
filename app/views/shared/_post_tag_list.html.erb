<%# Locals: post (required), wrapper_class: "" (optional, e.g., "pt-4 border-t border-border") %>
<% wrapper_class ||= "" %>
<% if post.tags.any? %>
  <div class="flex flex-wrap gap-2 <%= wrapper_class %>">
    <% post.tags.each do |tag| %>
      <%= link_to tag.name, tag_path(slug: tag.slug), class: "inline-block bg-bg-primary border border-border/50 text-text-secondary text-xs font-medium px-3 py-1 rounded-full hover:border-accent-green hover:text-accent-green transition-fast" %>
    <% end %>
  </div>
<% end %>
