<div class="group bg-bg-surface rounded-lg p-8 border border-border border-l-4 border-l-accent-green hover:border-accent-green transition-fast overflow-hidden relative mb-8">
  <!-- Glow effect on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-br from-accent-green/5 to-accent-green-light/10 pointer-events-none"></div>

  <div class="relative z-10">
    <!-- Featured badge -->
    <div class="inline-block text-xs font-semibold text-accent-green uppercase tracking-wider mb-3">
      ★ Latest
    </div>

    <!-- Title -->
    <h3 class="text-2xl md:text-3xl font-bold text-accent-green mb-4 group-hover:text-accent-green-light transition-fast leading-tight">
      <%= link_to post.title, post_show_path(slug: post.slug) %>
    </h3>

    <!-- Excerpt (full, no line clamp) -->
    <p class="text-text-secondary mb-6 text-base md:text-lg leading-relaxed">
      <%= post.excerpt %>
    </p>

    <!-- Meta + Tags -->
    <div class="flex flex-wrap items-center justify-between gap-4 pt-4 border-t border-border">
      <%= render "shared/post_meta", post: post, size_class: "text-sm" %>
      <%= render "shared/post_tag_list", post: post %>
    </div>
  </div>
</div>
