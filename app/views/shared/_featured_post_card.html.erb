<div class="group bg-bg-surface rounded-lg p-8 border border-border border-l-4 border-l-accent-green hover:border-accent-blue hover:border-l-accent-green transition-fast overflow-hidden relative mb-8">
  <!-- Glow effect on hover -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-br from-accent-blue/5 to-accent-green/5 pointer-events-none"></div>

  <div class="relative z-10">
    <!-- Featured badge -->
    <div class="inline-block text-xs font-semibold text-accent-green uppercase tracking-wider mb-3">
      ★ Latest
    </div>

    <!-- Title -->
    <h3 class="text-2xl md:text-3xl font-bold text-accent-blue mb-4 group-hover:text-accent-green transition-fast leading-tight">
      <%= link_to post.title, post_show_path(slug: post.slug) %>
    </h3>

    <!-- Excerpt (full, no line clamp) -->
    <p class="text-text-secondary mb-6 text-base md:text-lg leading-relaxed">
      <%= post.excerpt %>
    </p>

    <!-- Meta + Tags -->
    <div class="flex flex-wrap items-center justify-between gap-4 pt-4 border-t border-border">
      <span class="text-text-muted text-sm font-medium">
        <%= post.published_at.strftime("%b %d, %Y") %>
        <span>&middot;</span>
        <span><%= post.reading_time %> min read</span>
      </span>

      <% if post.tags.any? %>
        <div class="flex flex-wrap gap-2">
          <% post.tags.each do |tag| %>
            <%= link_to tag.name, tag_path(slug: tag.slug), class: "inline-block bg-bg-primary border border-border/50 text-text-secondary text-xs font-medium px-3 py-1 rounded-full hover:border-accent-blue hover:text-accent-blue transition-fast" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
