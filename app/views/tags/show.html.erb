<% content_for(:title) { "Posts tagged with #{@tag.name}" } %>
<% content_for(:og_title) { "Posts tagged with #{@tag.name} — Personal Blog" } %>
<% content_for(:og_description) { "Browse all posts tagged with #{@tag.name}." } %>
<% content_for(:head) do %>
  <%= json_ld_tag(breadcrumb_json_ld([
    { name: "Home", url: root_url },
    { name: "Tags", url: tags_url },
    { name: @tag.name, url: tag_url(slug: @tag.slug) }
  ])) %>
<% end %>

<div>
  <!-- Header -->
  <div class="mb-12">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-4xl font-bold text-text-primary">
        <span class="text-accent-green">#</span> <%= @tag.name %>
      </h1>
    </div>
    <p class="text-text-secondary">
      <%= pluralize(@posts.count, "post") %> tagged with "<%= @tag.name %>"
    </p>
  </div>

  <% if @posts.any? %>
    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <% @posts.each do |post| %>
        <%= render "shared/post_card", post: post %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-bg-surface border border-border rounded-lg p-12 text-center">
      <p class="text-text-secondary text-lg mb-6">No published posts with this tag yet.</p>
      <p class="text-text-muted text-sm">Check back soon for fresh content!</p>
    </div>
  <% end %>

  <!-- Back Link -->
  <div class="pt-8 border-t border-border">
    <%= link_to "← All Posts", posts_path, class: "text-accent-green hover:text-accent-green-light transition-fast" %>
  </div>
</div>
