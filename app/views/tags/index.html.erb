<% content_for(:title) { "Tags" } %>
<% content_for(:og_title) { "Tags — Esteban Soto" } %>
<% content_for(:og_description) { "Browse all topics and categories." } %>

<div>
  <!-- Header -->
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-text-primary mb-2">Tags</h1>
    <p class="text-text-secondary">Browse posts by topic</p>
  </div>

  <% if @tags.any? %>
    <!-- Tags Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(slug: tag.slug),
              class: "group bg-bg-surface border border-border rounded-lg p-5 hover:border-accent-green transition-fast" do %>
          <div class="flex items-center justify-between">
            <span class="text-lg font-medium text-accent-green group-hover:text-accent-green transition-fast">
              <span class="text-text-muted">#</span><%= tag.name %>
            </span>
            <span class="text-sm text-text-muted bg-bg-surface-hover rounded-full px-3 py-1">
              <%= tag.posts_count %>
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-bg-surface border border-border rounded-lg p-12 text-center">
      <p class="text-text-secondary text-lg mb-2">No tags yet.</p>
      <p class="text-text-muted text-sm">Tags will appear here once posts are tagged.</p>
    </div>
  <% end %>
</div>
