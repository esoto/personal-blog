<% content_for(:title) { @post.title } %>

<div>
  <!-- Back link -->
  <div class="mb-8">
    <%= link_to "← Back to posts", posts_path, class: "text-accent-blue hover:text-accent-green transition-fast inline-block" %>
  </div>

  <!-- Post header -->
  <article class="bg-bg-surface border border-border rounded-lg p-8 md:p-12 mb-8">
    <header>
      <!-- Title -->
      <h1 class="text-4xl md:text-5xl font-bold text-text-primary mb-6"><%= @post.title %></h1>

      <!-- Meta Information -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pb-6 border-b border-border">
        <!-- Date -->
        <span class="text-text-secondary text-sm font-medium">
          <svg class="inline w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <%= @post.published_at.strftime("%B %d, %Y") %>
        </span>

        <!-- Tags -->
        <% if @post.tags.any? %>
          <div class="flex flex-wrap gap-2">
            <% @post.tags.each do |tag| %>
              <span class="inline-block bg-bg-primary border border-border text-text-secondary text-xs font-medium px-3 py-1 rounded-full">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <!-- Post body -->
    <div class="prose-dark mt-8" data-controller="highlight">
      <%= @post.body %>
    </div>
  </article>

  <!-- Back link at bottom -->
  <div class="flex justify-between items-center pt-6 border-t border-border">
    <%= link_to "← Back to posts", posts_path, class: "text-accent-blue hover:text-accent-green transition-fast" %>
    <% if @post.tags.any? %>
      <div class="flex gap-2 text-xs text-text-secondary">
        <span class="font-medium">Tagged:</span>
        <% @post.tags.first(2).each do |tag| %>
          <span><%= tag.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
