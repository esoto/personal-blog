<% content_for(:title) { @post.title } %>

<div class="max-w-3xl mx-auto">
  <!-- Back link -->
  <div class="mb-8">
    <%= link_to "← Back to posts", posts_path, class: "text-blue-400 hover:text-blue-300 transition-colors" %>
  </div>

  <!-- Post header -->
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-100 mb-4"><%= @post.title %></h1>

    <div class="flex items-center gap-4 mb-6">
      <span class="text-gray-400 text-sm">
        <%= @post.published_at.strftime("%b %d, %Y") %>
      </span>

      <% if @post.tags.any? %>
        <div class="flex flex-wrap gap-2">
          <% @post.tags.each do |tag| %>
            <span class="inline-block bg-gray-700 text-gray-200 text-xs font-semibold px-3 py-1 rounded-full">
              <%= tag.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="h-px bg-gray-700 mb-8"></div>
  </div>

  <!-- Post body -->
  <div class="prose prose-invert max-w-none mb-12">
    <%= @post.body %>
  </div>

  <!-- Back link at bottom -->
  <div class="pt-8 border-t border-gray-700">
    <%= link_to "← Back to posts", posts_path, class: "text-blue-400 hover:text-blue-300 transition-colors" %>
  </div>
</div>
