<div id="comments_list">
  <% if comments.any? %>
    <h3 class="text-xl font-bold text-text-primary mb-6">
      <%= pluralize(comments.size, "Comment") %>
    </h3>

    <div class="space-y-6">
      <% comments.each do |comment| %>
        <div class="bg-bg-surface border border-border rounded-lg p-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-accent-blue/20 rounded-full flex items-center justify-center">
              <span class="text-accent-blue text-sm font-bold"><%= comment.author_name&.first&.upcase %></span>
            </div>
            <div>
              <span class="text-text-primary font-medium text-sm"><%= comment.author_name %></span>
              <span class="text-text-muted text-xs ml-2"><%= time_ago_in_words(comment.created_at) %> ago</span>
            </div>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed whitespace-pre-wrap"><%= comment.body %></p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
