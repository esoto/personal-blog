<% content_for(:title) { "Esteban Soto — Full-Stack Developer" } %>
<% content_for(:og_title) { "Esteban Soto — Full-Stack Developer" } %>
<% content_for(:og_description) { "Rails developer since 2012. Writing about databases, Rails, and what I'm learning from using AI as a coding partner." } %>
<% content_for(:head) { json_ld_tag(website_json_ld) } %>

<style>
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .blinking-cursor {
    animation: blink 1s infinite;
  }
</style>

<!-- Hero Section -->
<section class="py-16 md:py-20 flex flex-col items-center mb-12 px-4 bg-gradient-to-b from-bg-primary via-bg-primary to-bg-surface rounded-lg border border-border">
  <div class="max-w-2xl text-center">
    <!-- Terminal Prompt -->
    <div class="text-accent-green text-2xl md:text-3xl font-bold mb-8 flex items-center justify-center gap-2 font-mono">
      <span>&gt;_</span>
      <span class="blinking-cursor">|</span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-8">
      <span class="text-accent-green">Esteban Soto</span>
    </h1>

    <!-- Tagline -->
    <p class="text-lg md:text-xl text-text-secondary mb-10 font-light leading-relaxed">
      Rails developer since 2012. Writing about <span class="text-accent-green font-medium">databases</span>, <span class="text-accent-green font-medium">Rails</span>, and what I'm learning from using <span class="text-accent-green font-medium">AI</span> as a coding partner.
    </p>

    <!-- Latest Post Hint -->
    <% if @posts.any? %>
      <p class="text-sm text-text-muted mb-10">
        Latest: <%= link_to "#{@posts.first.title} →", post_show_path(slug: @posts.first.slug), class: "text-accent-green hover:text-accent-green-light font-medium transition-fast" %>
      </p>
    <% end %>

    <!-- CTA -->
    <div class="flex flex-col items-center gap-5">
      <a href="#posts" class="inline-block px-8 py-3 bg-accent-green hover:bg-accent-green/90 text-bg-primary font-bold rounded-lg transition-fast">
        Read Latest Posts
      </a>
      <a href="https://github.com/esoto" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted hover:text-accent-green transition-fast">
        or find me on GitHub →
      </a>
    </div>
  </div>
</section>

<!-- Latest Posts Section -->
<section id="posts" class="mb-20">
  <!-- Section Header -->
  <div class="mb-8">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-3">
      <span class="text-accent-green">Latest</span> Posts
    </h2>
    <div class="h-1 w-32 bg-gradient-to-r from-accent-green to-accent-green-light rounded-full"></div>
  </div>

  <!-- Posts -->
  <% if @posts.any? %>
    <!-- Featured latest post -->
    <%= render "shared/featured_post_card", post: @posts.first %>

    <!-- Remaining posts grid -->
    <% if @posts.length > 1 %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @posts.drop(1).each do |post| %>
          <%= render "shared/post_card", post: post %>
        <% end %>
      </div>
    <% end %>

    <!-- View All Posts Link -->
    <div class="mt-12 text-center">
      <%= link_to "View All Posts →", posts_path, class: "inline-block px-6 py-3 text-accent-green hover:text-accent-green-light font-semibold transition-fast" %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-bg-surface rounded-lg p-12 border border-border text-center">
      <p class="text-text-secondary text-lg mb-2">
        <span class="text-accent-orange">No posts yet</span> — check back soon for fresh content!
      </p>
      <p class="text-text-muted text-sm">New articles coming soon...</p>
    </div>
  <% end %>
</section>
