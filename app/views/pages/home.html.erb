<% content_for(:og_title) { "Esteban Soto — Full-Stack Developer" } %>
<% content_for(:og_description) { "Exploring code, design, and the intersection of technology and creativity." } %>
<% content_for(:head) { json_ld_tag(website_json_ld) } %>

<style>
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .blinking-cursor {
    animation: blink 1s infinite;
  }
</style>

<!-- Hero Section -->
<section class="min-h-[600px] flex flex-col justify-center items-center mb-20 px-4 bg-gradient-to-b from-bg-primary via-bg-primary to-bg-surface rounded-lg border border-border">
  <div class="max-w-2xl text-center">
    <!-- Terminal Prompt -->
    <div class="text-accent-green text-2xl md:text-3xl font-bold mb-8 flex items-center justify-center gap-2 font-mono">
      <span>&gt;_</span>
      <span class="blinking-cursor">|</span>
    </div>

    <!-- Main Heading -->
    <h1 class="text-4xl md:text-6xl font-bold text-text-primary mb-6">
      <span class="text-accent-blue">Esteban Soto</span>
    </h1>
    <p class="text-xl md:text-2xl text-text-secondary mb-4 font-light">
      Full-Stack Developer
    </p>

    <!-- Tagline -->
    <p class="text-lg md:text-xl text-text-secondary mb-12 font-light leading-relaxed">
      Building with <span class="text-accent-blue font-medium">Ruby</span> and <span class="text-accent-blue font-medium">JavaScript</span>. Writing about code, tools, and what I learn along the way.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#posts" class="inline-block px-8 py-3 bg-accent-blue hover:bg-accent-blue/90 text-bg-primary font-bold rounded-lg transition-fast">
        Read Latest Posts
      </a>
      <a href="https://github.com/esoto" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 border-2 border-accent-blue hover:bg-accent-blue/10 text-accent-blue font-bold rounded-lg transition-fast">
        GitHub
      </a>
    </div>
  </div>
</section>

<!-- Latest Posts Section -->
<section id="posts" class="mb-20">
  <!-- Section Header -->
  <div class="mb-12">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-3">
      <span class="text-accent-green">Latest</span> Posts
    </h2>
    <div class="h-1 w-32 bg-gradient-to-r from-accent-green to-accent-blue rounded-full"></div>
  </div>

  <!-- Posts Grid -->
  <% if @posts.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @posts.each do |post| %>
        <%= render "shared/post_card", post: post %>
      <% end %>
    </div>

    <!-- View All Posts Link -->
    <div class="mt-12 text-center">
      <%= link_to "View All Posts →", posts_path, class: "inline-block px-6 py-3 text-accent-blue hover:text-accent-green font-semibold transition-fast" %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="bg-bg-surface rounded-lg p-12 border border-border text-center">
      <p class="text-text-secondary text-lg mb-2">
        <span class="text-accent-orange">No posts yet</span> — check back soon for fresh content!
      </p>
      <p class="text-text-muted text-sm">New articles coming soon...</p>
    </div>
  <% end %>
</section>
