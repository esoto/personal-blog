<% content_for(:title) { "About" } %>
<% content_for(:og_title) { "About — Esteban Soto" } %>
<% content_for(:og_description) { "Full-stack developer building with Ruby and JavaScript." } %>
<% content_for(:head) { json_ld_tag(person_json_ld) } %>

<div>
  <!-- Header -->
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-text-primary mb-2">About Me</h1>
    <p class="text-text-secondary">A bit about who I am and what I do</p>
  </div>

  <!-- Bio Section -->
  <div class="bg-bg-surface border border-border rounded-lg p-8 mb-8">
    <div class="prose-custom">
      <p class="text-text-primary text-lg leading-relaxed mb-6">
        Hi, I'm <span class="text-accent-blue font-medium">Esteban Soto</span> — a full-stack developer who builds with Ruby and JavaScript. I enjoy turning ideas into clean, well-tested code.
      </p>

      <p class="text-text-secondary leading-relaxed mb-6">
        I write about software development, engineering practices, and the tools I use daily. This blog is my space to share what I learn and think through problems in public.
      </p>

      <p class="text-text-secondary leading-relaxed">
        When I'm not coding, you'll find me exploring new technologies, contributing to open source, or enjoying a good cup of coffee.
      </p>
    </div>
  </div>

  <!-- Links Section -->
  <div class="bg-bg-surface border border-border rounded-lg p-8 mb-8">
    <h2 class="text-2xl font-bold text-text-primary mb-6">Find Me Online</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="https://github.com/esoto" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 bg-bg-primary border border-border rounded-lg hover:border-accent-blue transition-fast group">
        <svg class="w-5 h-5 text-text-secondary group-hover:text-accent-blue transition-fast" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span class="text-text-secondary group-hover:text-accent-blue transition-fast">GitHub</span>
      </a>
      <a href="https://www.linkedin.com/in/soto-esteban/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 bg-bg-primary border border-border rounded-lg hover:border-accent-blue transition-fast group">
        <svg class="w-5 h-5 text-text-secondary group-hover:text-accent-blue transition-fast" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span class="text-text-secondary group-hover:text-accent-blue transition-fast">LinkedIn</span>
      </a>
      <%= link_to feed_path(format: :rss), class: "flex items-center gap-3 p-4 bg-bg-primary border border-border rounded-lg hover:border-accent-orange transition-fast group" do %>
        <svg class="w-5 h-5 text-text-secondary group-hover:text-accent-orange transition-fast" fill="currentColor" viewBox="0 0 24 24"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795 0 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.742-7.098-15.771-15.839-15.82zm0-8.18v4.819c12.951.115 23.413 10.696 23.413 23.625h.087v.576h4.5v-.576c0-15.762-12.802-28.543-28-28.444z"/></svg>
        <span class="text-text-secondary group-hover:text-accent-orange transition-fast">RSS Feed</span>
      <% end %>
    </div>
  </div>

  <!-- Back Link -->
  <div class="pt-8 border-t border-border">
    <%= link_to "← Back to Home", root_path, class: "text-accent-blue hover:text-accent-green transition-fast" %>
  </div>
</div>
